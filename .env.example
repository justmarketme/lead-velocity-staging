# Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the actual .env file — it is in .gitignore.

VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_GEMINI_API_KEY="your-gemini-api-key"
GEMINI_API_KEY="your-gemini-api-key"

# Twilio (calls, SMS, WhatsApp)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="your-default-twilio-number"
TWILIO_SA_PHONE_NUMBER="+27XXXXXXXXX"

# ElevenLabs (AI voice agents for outbound campaigns)
ELEVENLABS_API_KEY="your-elevenlabs-api-key"

# Ultravox (conversational AI brain — pairs with ElevenLabs for lowest latency calls)
ULTRAVOX_API_KEY="your-ultravox-api-key"

# Lead scraping providers (optional — Gemini fallback used if not set)
FIRECRAWL_API_KEY="your-firecrawl-api-key"
TAVILY_API_KEY="your-tavily-api-key"

# n8n workflow automation
# When set, AI campaign launches are routed through n8n (handles rate limiting & batching)
# Leave blank to use direct edge function invocation instead
VITE_N8N_CAMPAIGN_WEBHOOK="http://localhost:5678/webhook/outbound-campaign-calls"
